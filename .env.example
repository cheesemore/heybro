# OpenAI Images API (optional — only for scripts/enemy-art-pipeline.mjs)
# OPENAI_API_KEY=

# When "true", preload all public/assets/enemies/<EnemyPaintKind>.png that exist; missing files fall back to vector art.
# VITE_ENEMY_TEXTURES=false

# Legacy: when "true" and VITE_ENEMY_TEXTURES is not true, only preload grunt.png
# VITE_ENEMY_GRUNT_TEXTURE=false

# Arena PvP: POST arena comm record (JSON body) for matchmaking
# 缺省为 https://game.immortalis.cn/heybro/back/v1/match；可覆盖为其它环境
# VITE_ARENA_API_URL=https://game.immortalis.cn/heybro/back/v1/match
